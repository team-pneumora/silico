# ============================================
# Silico — Environment Variables
# Copy this file to .env and fill in your keys
# ============================================

# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Notion
NOTION_MCP_URL=https://mcp.notion.com/mcp
NOTION_MESSAGES_DB_ID=xxx
NOTION_TASKS_DB_ID=xxx
NOTION_COMPANY_STATE_DB_ID=xxx
NOTION_DECISIONS_DB_ID=xxx
NOTION_ROUND_LOG_DB_ID=xxx

# Exchange (Binance Futures Testnet first, then real)
EXCHANGE_API_KEY=xxx
EXCHANGE_API_SECRET=xxx
EXCHANGE_BASE_URL=https://testnet.binancefuture.com

# Vercel
VERCEL_MCP_URL=https://mcp.vercel.com

# GitHub
GITHUB_MCP_URL=https://api.github.com
GITHUB_TOKEN=ghp_xxx

# Gmail
GMAIL_MCP_URL=https://gmail.mcp.claude.com/mcp

# Google Calendar
GCAL_MCP_URL=https://gcal.mcp.claude.com/mcp

# Orchestrator
ROUND_INTERVAL_MINUTES=60
MAX_ROUNDS_PER_DAY=24
AGENT_MODEL=claude-sonnet-4-20250514
