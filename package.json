  "keywords": [
    "ai-agents",
    "orchestrator",
    "autonomous",
    "claude"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@supabase/supabase-js": "^2.99.3",
    "dotenv": "^16.4.0",
    "node-cron": "^3.0.0",
    "winston": "^3.17.0",
    "zod": "^3.24.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
