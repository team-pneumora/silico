{
  "name": "silico",
  "version": "0.1.0",
  "description": "Silico — AI-only company orchestrator with autonomous CEO and Developer agents",
  "type": "module",
  "main": "dist/orchestrator/index.js",
  "scripts": {
    "start": "ts-node --esm src/orchestrator/index.ts",
    "dev": "ts-node --esm src/orchestrator/index.ts --once",
    "init": "ts-node --esm src/orchestrator/index.ts --init",
    "build": "tsc",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
